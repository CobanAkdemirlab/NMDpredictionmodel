PTC.df <- data.frame(chr=df$contig,start=df$position,end=df$position)
PTC.grange <- makeGRangesFromDataFrame(PTC.df)
#utr.resized=resize(cds.grange$ENST00000002125.8[9:10],width=400,fix='start')

PTC.grange.1 <- PTC.grange+100

cds.grange<- cdsBy(ensgene, by="tx",use.names=TRUE)
merged <- list()
for (i in 1:nrow(PTC.df)) {
  
  print(i)
  txname <- df$txnames[i]
  ind <- which(names(cds.grange) == txname)
  
  # If no transcript found, skip to the next iteration
  if (length(ind) == 0) {
    next
  }
  
  r.1 <- cds.grange[[ind]]
  
  sub.ind <- subjectHits(findOverlaps(PTC.grange[i], r.1))
  
  # If no overlaps found, skip to the next iteration
  if (length(sub.ind) == 0) {
    next
  }
  
  range <- r.1[sub.ind]
  
  # Check if range is valid (not empty)
  if (length(range) == 0) {
    next
  }
  
  if (as.character(runValue(strand(range))) == '+') {
    
    # Resize range for the positive strand
    resized.range <- resize(range, width = end(range) - df$position[i] + 1, fix = 'end')
    
  } else if (as.character(runValue(strand(range))) == '-') {
    
    # Resize range for the negative strand
    resized.range <- resize(range, width = df$position[i] - start(range) + 1, fix = 'start')
    
  } else {
    # If the strand is not "+" or "-", skip this iteration
    next
  }
  
  # Update the range in r.1
  r.1[sub.ind] <- resized.range
  
  exon.no <- r.1$exon_rank[sub.ind]
  
  exon.ind <- which(r.1$exon_rank >= exon.no)
  
  c1 <- r.1[exon.ind]
  
  ### Add 3' UTR sequence as well
  ind.1 <- which(names(utr.grange) == txname)
  
  c2 <- NULL
  if (length(ind.1) > 0) {
    c2 <- utr.grange[[ind.1]]
  }
  
  merged[[i]] <- c(c1, c2)
  merged[[i]]$exon_rank <- c(min(merged[[i]]$exon_rank):(min(merged[[i]]$exon_rank) + length(merged[[i]]) - 1))
}
# Remove NULL entries from the merged list
merged <- Filter(Negate(is.null), merged)

# Check if there are valid entries in the merged list
if (length(merged) == 0) {
  stop("The 'merged' list is empty after removing NULL entries. No valid GRanges to process.")
}
## Then Create a GRangesList from the filtered merged list

