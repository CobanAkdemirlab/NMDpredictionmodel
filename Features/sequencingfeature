    if (length(grep('_',cod.pos))==1) {
      cod.pos <- strsplit(cod.pos,'_')[[1]][1]
      as.numeric(gsub("\\D", "", cod.pos))
    } else {
      
      as.numeric(gsub("\\D", "", cod.pos))
    }
  } else 
  {
