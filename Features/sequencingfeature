variants.features.fr$coding.pos <-  sapply(1:nrow(variants.features.fr),function(x)
  
{
  print(x)
  ens.annotated <- variants.features.fr$V3[x]
  pos <- strsplit(ens.annotated,':')
  cod.pos <- pos[[1]][grep(variants.features.fr$txnames[x],pos[[1]])+2]
