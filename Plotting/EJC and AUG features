def collapse_aug_distance(cat):
    if cat in ["very_close", "close"]:
        return "Close"
    elif cat == "moderate":
        return "Moderate"
    elif cat in ["far", "very_far"]:
        return "Far"
    else:
        return np.nan

df["aug_dist_3cat"] = df["aug_distance_category"].apply(collapse_aug_distance)
df = df.dropna(subset=["aug_dist_3cat", "ALLELE.RAT"])

plot_categorical_vs_nmd(
    df,
    cat_col="aug_dist_3cat",
    order=["Close", "Moderate", "Far"],
    title_base="Downstream in-frame AUG",
    pairs="auto"
)
