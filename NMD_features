get_NSD_boundary_minus1 <- function(x)
  #get_NMD_ind_plus1(cds_seqs,all.df.sub$TXNAME)
{
  a <- unlist(cds_seqs[x])
  name <- names(cds_seqs[x])
  ind <- unlist(gregexpr('TAG|TAA|TGA',as.character(a)))
  plus1.ind <- ind[which(ind%%3==0)]
  finalPTC<-max(plus1.ind)
  df <- all.df.sub[which(all.df.sub$TXNAME==name),]
  cds.df<-df[!is.na(df$CDSID),]
  exon.length <- (cds.df$CDSEND-cds.df$CDSSTART)+1
  exon.number<-nrow(cds.df)
  
  aft.NMD.ind <- sum(exon.length[1:length(exon.length)-1])-50
  ###this signifies the nucleotide(c.XX) that is the 50bp rule position
  
  
  
  escapingPTCs<-which(plus1.ind >= aft.NMD.ind)
  pre.plus1.ind.NMD <- min(which(plus1.ind >= aft.NMD.ind))
  plus1.ind.NMD <- pre.plus1.ind.NMD-1
  
  
  if (exon.number == 1) {
    return(finalPTC)
  }  
  else if (length(escapingPTCs)==0) {
    max()
    return('NSDonly_no_escapePTCs')
  } 
  else if (plus1.ind.NMD>0){
    return(plus1.ind[plus1.ind.NMD])
  }
  else if (plus1.ind.NMD==0){
    return(1)
  }
  else return('NO flaggable PTC')
}

