ptc.exon<- function(x)
{
  print(x)
  name <- names(cds_seqs[x])
  d<-data[which(data$NAME==name),]
  ds<-unlist(strsplit(as.character(d[4]),split= ","))
  e<-min(which(as.numeric(ds) > as.numeric(d$minus1.boundary)))
